@page
@model AuthServer.Host.Pages.Profile.IndexModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="row mt-4">
    <!-- Боковое меню навигации Личного кабинета -->
    <div class="col-md-3">
        <div class="list-group">
            <a asp-page="./Index" class="list-group-item list-group-item-action active">Профиль</a>
            <a asp-page="./Security" class="list-group-item list-group-item-action">Безопасность</a>
            <a asp-page="./ExternalLogins" class="list-group-item list-group-item-action">Привязанные аккаунты</a>
            <a asp-page="./Applications" class="list-group-item list-group-item-action">Мои приложения (Consent)</a>
        </div>
    </div>

    <!-- Основной контент -->
    <div class="col-md-9">
        <h4>Управление профилем</h4>
        <hr />

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @Model.StatusMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <div class="col-md-6">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group mb-3">
                        <label>Email (Учетная запись)</label>
                        <div class="input-group">
                            <input value="@Model.Email" class="form-control" disabled />
                            @if (Model.IsEmailConfirmed)
                            {
                                <span class="input-group-text text-success font-weight-bold">✓ Подтвержден</span>
                            }
                            else
                            {
                                <button type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-warning">Отправить подтверждение</button>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Input.FirstName"></label>
                        <input asp-for="Input.FirstName" class="form-control" />
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.LastName"></label>
                        <input asp-for="Input.LastName" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}