@page
@model AuthServer.Host.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Сброс пароля";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 login-container">
        <h2 class="text-center">@ViewData["Title"]</h2>
        <p class="text-center text-muted">Придумайте новый пароль для <strong>@Model.Input.Email</strong></p>
        <hr />
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input asp-for="Input.Code" type="hidden" />
            <input asp-for="Input.Email" type="hidden" />

            <div class="form-group mb-3">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Input.ConfirmPassword"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Сохранить новый пароль</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}