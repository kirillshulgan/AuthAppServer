@page
@model AuthServer.Host.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Восстановление пароля";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 login-container">
        <h2 class="text-center">@ViewData["Title"]</h2>
        <p class="text-center text-muted">Введите ваш email, и мы отправим ссылку для сброса пароля.</p>
        <hr />
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-2">Отправить ссылку</button>
            <a asp-page="./Login" class="btn btn-outline-secondary w-100">Отмена</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}