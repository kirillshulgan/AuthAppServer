@page
@model AuthServer.Host.Pages.Account.ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Пароль изменен";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 login-container text-center">
        <h2 class="mb-4">@ViewData["Title"]</h2>

        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            Ваш пароль был успешно изменен.
        </div>

        <p class="mt-4">
            <a asp-page="./Login" class="btn btn-primary w-100">Перейти на страницу входа</a>
        </p>
    </div>
</div>